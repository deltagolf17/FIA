# ─── Database ─────────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL — e.g. Neon, Supabase, Railway):
# DATABASE_URL="postgresql://user:password@host:5432/firetrace?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# Your deployment URL (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic (AI Cause Analysis) ───────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Email (Incendiary & Review Alerts) ──────────────────────────────────────
# Get your key at: https://resend.com — optional, alerts log to console if absent
RESEND_API_KEY="re_..."
# Sender address (must be a verified domain in Resend)
EMAIL_FROM="FireTrace Pro <alerts@firetrace.app>"
