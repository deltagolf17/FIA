# ─── Database (PostgreSQL required) ──────────────────────────────────────────
#
# Neon (recommended — free tier at neon.tech):
#   DATABASE_URL = pooled connection string  (used by the app at runtime)
#   DIRECT_URL   = direct connection string  (used by prisma migrate)
#
# Supabase: Settings → Database → URI (pooler → DATABASE_URL, direct → DIRECT_URL)
# Railway / Render: both values are typically the same connection string
#
DATABASE_URL="postgresql://user:password@host:5432/firetrace?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/firetrace?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate secret:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"
# Your deployment URL — no trailing slash
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic (AI Cause Analysis) ───────────────────────────────────────────
# Required for the AI cause suggestion feature
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Required for the Active Cases map on the dashboard
# Get your key at: https://console.cloud.google.com → Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── Email Alerts (optional) ─────────────────────────────────────────────────
# Incendiary fire and pending-review alerts via Resend
# Get your key at: https://resend.com  — alerts silently skip if absent
RESEND_API_KEY="re_..."
# Must be a verified sending domain in Resend
EMAIL_FROM="FireTrace Pro <alerts@yourdomain.com>"

# ─── File Storage (optional) ─────────────────────────────────────────────────
# Evidence photo uploads via UploadThing
# Get credentials at: https://uploadthing.com
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="your-app-id"
